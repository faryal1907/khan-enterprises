// ============================================================================
// KHAN DEALERSHIP PLATFORM
// Production-Grade Prisma Schema
// Stack: PostgreSQL + Prisma + NestJS
// ============================================================================

generator client {
  provider     = "prisma-client"
  output       = "./generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  ADMIN
  MANAGER
  SALES_STAFF
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum BikeStatus {
  AVAILABLE
  RESERVED
  SOLD
  IN_DELIVERY
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  CONFIRMED
  READY_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum DeliveryStatus {
  REQUESTED
  UNDER_REVIEW
  APPROVED
  IN_TRANSIT
  DELIVERED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  VERIFICATION_PENDING
  CANCELLED
}

enum PaymentMethod {
  CASH
  ONLINE_TRANSFER
}

enum OrderType {
  ONLINE
  ONSITE
}

enum PickupType {
  DELIVERY
  ONSITE_PICKUP
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  PAYMENT
}

enum InventoryMovementType {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
  TRANSFER
  RESERVED
  RELEASED
}

enum FileType {
  SUPPLIER_INVOICE
  WARRANTY_DOCUMENT
  REGISTRATION_DOCUMENT
  SALES_INVOICE
  PAYMENT_RECEIPT
  SALE_AGREEMENT
}

enum ExpenseCategory {
  UTILITIES
  RENT
  MAINTENANCE
  SALARY
  MARKETING
  OTHER
}

// ============================================================================
// AUTH & USERS
// ============================================================================

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  fullName     String
  phoneNumber  String?
  role         UserRole
  status       UserStatus @default(ACTIVE)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  vendorId String?
  vendor   Vendor? @relation(fields: [vendorId], references: [id])

  refreshTokens      RefreshToken[]
  passwordResetTokens PasswordResetToken[]

  auditLogs AuditLog[]

  processedOrders     Order[]     @relation("OrderProcessedBy")
  customerOrders      Order[]     @relation("OrderCustomer")
  processedPartOrders PartOrder[] @relation("PartOrderProcessedBy")
  customerPartOrders  PartOrder[] @relation("PartOrderCustomer")

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  managedBranches Branch[]        @relation("BranchManager")
  stockMovements  StockMovement[]
  documents       Document[]
  orderAlerts     OrderAlert[]
  recordedExpenses Expense[]
  
  fcmTokens       String[]        @default([])

  @@index([email])
  @@index([role])
  @@index([branchId])
  @@index([vendorId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  expiresAt DateTime

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([tokenHash])
  @@index([userId])
}

// ============================================================================
// BRANCHES & VENDORS
// ============================================================================

model Branch {
  id          String  @id @default(uuid())
  name        String
  city        String
  address     String
  phoneNumber String?
  latitude    Float?
  longitude   Float?

  managerId String?
  manager   User?   @relation("BranchManager", fields: [managerId], references: [id])

  users User[]

  bikeInventory BikeUnit[]
  partInventory PartInventory[]

  orders     Order[]
  partOrders PartOrder[]
  expenses   Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, city])
}

model Vendor {
  id            String  @id @default(uuid())
  name          String
  contactPerson String?
  phoneNumber   String?
  email         String?
  address       String?

  suppliedBikes BikeUnit[]
  staff         User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// BIKE CATALOG
// ============================================================================

model BikeModel {
  id String @id @default(uuid())

  brand          String
  modelName      String
  year           Int
  engineCapacity String?
  colors         String[] @default([])

  description String?
  basePrice   Decimal @db.Decimal(12, 2)

  bikes BikeUnit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brand])
  @@index([modelName])
}

model BikeUnit {
  id String @id @default(uuid())

  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id])

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  modelId String
  model   BikeModel @relation(fields: [modelId], references: [id])

  chassisNumber String  @unique
  engineNumber  String  @unique
  serialNumber  String?

  status BikeStatus @default(AVAILABLE)

  price Decimal? @db.Decimal(12, 2)
  color String?
  media String[] @default([])

  onlineDiscountPercent Decimal  @default(0) @db.Decimal(5, 2)
  actualSalePrice       Decimal? @db.Decimal(12, 2)

  reservedUntil DateTime?
  soldAt        DateTime?

  documents Document[]

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([branchId])
  @@index([modelId])
  @@index([vendorId])
  @@index([reservedUntil])
}

// ============================================================================
// PARTS & ACCESSORIES
// ============================================================================

model Part {
  id String @id @default(uuid())

  name     String
  sku      String @unique
  category String

  description  String?
  sellingPrice Decimal @db.Decimal(12, 2)

  inventories PartInventory[]
  partOrders  PartOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model PartInventory {
  id String @id @default(uuid())

  partId String
  part   Part   @relation(fields: [partId], references: [id])

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  quantity         Int @default(0)
  reservedQuantity Int @default(0)
  reorderLevel     Int @default(5)

  onlineDiscountPercent Decimal  @default(0) @db.Decimal(5, 2)

  stockMovements StockMovement[]
  partOrders     PartOrder[]

  updatedAt DateTime @updatedAt

  @@unique([partId, branchId])
  @@index([branchId])
}

model StockMovement {
  id String @id @default(uuid())

  inventoryId String
  inventory   PartInventory @relation(fields: [inventoryId], references: [id])

  movementType InventoryMovementType

  quantity Int
  reason   String?

  performedById String?
  performedBy   User?   @relation(fields: [performedById], references: [id])

  createdAt DateTime @default(now())

  @@index([inventoryId])
}

// ============================================================================
// ORDERS
// ============================================================================

model Order {
  id String @id @default(uuid())

  orderNumber String @unique

  bikeId String
  bike   BikeUnit @relation(fields: [bikeId], references: [id])

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  customerName    String
  customerPhone   String
  customerCNIC    String?
  customerAddress String?

  isOnlineOrder   Boolean  @default(false)
  appliedDiscount Decimal? @db.Decimal(12, 2)

  paymentMethod PaymentMethod

  status OrderStatus @default(PENDING_PAYMENT)

  paymentVerified   Boolean    @default(false)
  orderType         OrderType  @default(ONSITE)
  reservationExpiry DateTime?
  pickupType        PickupType @default(ONSITE_PICKUP)

  expiresAt DateTime?

  processedById String?
  processedBy   User?   @relation("OrderProcessedBy", fields: [processedById], references: [id])

  customerId String?
  customer   User?   @relation("OrderCustomer", fields: [customerId], references: [id])

  transactions PaymentTransaction[]

  delivery DeliveryRequest?

  documents Document[]

  alerts OrderAlert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([branchId])
  @@index([createdAt])
  @@index([customerId])
}

model OrderAlert {
  id          String   @id @default(uuid())
  
  orderId     String?
  order       Order?   @relation(fields: [orderId], references: [id])
  
  partOrderId String?
  partOrder   PartOrder? @relation(fields: [partOrderId], references: [id])
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  isRead      Boolean  @default(false)
  alertType   String   // NEW_ORDER, PAYMENT_PENDING, EXPIRY_WARNING, DELIVERY_REQUEST
  createdAt   DateTime @default(now())

  @@index([userId, isRead])
}

model PartOrder {
  id String @id @default(uuid())

  orderNumber String @unique

  partId String
  part   Part   @relation(fields: [partId], references: [id])

  partInventoryId String
  partInventory   PartInventory @relation(fields: [partInventoryId], references: [id])

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  customerName    String
  customerPhone   String
  customerAddress String?

  quantity Int
  amount   Decimal @db.Decimal(12, 2)

  paymentMethod PaymentMethod

  status OrderStatus @default(PENDING_PAYMENT)

  paymentVerified   Boolean    @default(false)
  orderType         OrderType  @default(ONSITE)
  reservationExpiry DateTime?
  pickupType        PickupType @default(ONSITE_PICKUP)

  expiresAt DateTime?

  processedById String?
  processedBy   User?   @relation("PartOrderProcessedBy", fields: [processedById], references: [id])

  customerId String?
  customer   User?   @relation("PartOrderCustomer", fields: [customerId], references: [id])

  transactions PartPaymentTransaction[]

  delivery DeliveryRequest?
  
  alerts OrderAlert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([branchId])
  @@index([createdAt])
  @@index([customerId])
}

// ============================================================================
// PAYMENTS
// ============================================================================

model PaymentTransaction {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  gatewayReference String? @unique
  idempotencyKey   String? @unique

  amount Decimal @db.Decimal(12, 2)

  method PaymentMethod

  status PaymentStatus @default(PENDING)

  gatewayResponse Json?

  failureReason String?

  paymentProofUrl String?
  verifiedAt      DateTime?
  verifiedById    String?

  webhookReceivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([gatewayReference])
}

model PartPaymentTransaction {
  id String @id @default(uuid())

  partOrderId String
  partOrder   PartOrder @relation(fields: [partOrderId], references: [id])

  gatewayReference String? @unique
  idempotencyKey   String? @unique

  amount Decimal @db.Decimal(12, 2)

  method PaymentMethod

  status PaymentStatus @default(PENDING)

  gatewayResponse Json?

  failureReason String?

  paymentProofUrl String?
  verifiedAt      DateTime?
  verifiedById    String?

  webhookReceivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([gatewayReference])
}

// ============================================================================
// EXPENSES
// ============================================================================

model Expense {
  id String @id @default(uuid())

  amount      Decimal @db.Decimal(12, 2)
  date        DateTime
  category    ExpenseCategory
  description String?

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  recordedById String
  recordedBy   User   @relation(fields: [recordedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId])
  @@index([recordedById])
  @@index([date])
}

// ============================================================================
// DELIVERY
// ============================================================================

model DeliveryRequest {
  id String @id @default(uuid())

  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id])

  partOrderId String?
  partOrder   PartOrder? @relation(fields: [partOrderId], references: [id])

  deliveryAddress     String
  preferredTimeWindow String?
  contactNumber       String

  latitude           Float?
  longitude          Float?
  distanceFromBranch Float?
  deliveryCost       Decimal? @db.Decimal(12, 2)

  status DeliveryStatus @default(REQUESTED)

  approvedAt  DateTime?
  deliveredAt DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orderId])
  @@unique([partOrderId])
  @@index([status])
}

// ============================================================================
// DOCUMENT MANAGEMENT
// ============================================================================

model Document {
  id String @id @default(uuid())

  fileName String
  fileUrl  String

  mimeType String
  fileSize Int

  fileType FileType

  bikeId String?
  bike   BikeUnit? @relation(fields: [bikeId], references: [id])

  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id])

  uploadedById String?
  uploadedBy   User?   @relation(fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())

  @@index([fileType])
}

// ============================================================================
// AUDIT LOGS
// ============================================================================

model AuditLog {
  id String @id @default(uuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  userRole UserRole?

  action AuditAction

  entityType String
  entityId   String

  oldValue Json?
  newValue Json?

  ipAddress String?

  createdAt DateTime @default(now())

  @@index([entityType])
  @@index([entityId])
  @@index([action])
  @@index([createdAt])
}

// ============================================================================
// SYSTEM SETTINGS
// ============================================================================

model SystemSetting {
  id    String @id @default(uuid())
  key   String @unique // e.g. "GLOBAL_BIKE_DISCOUNT", "GLOBAL_PART_DISCOUNT"
  value String // JSON encoded or plain string

  updatedAt DateTime @updatedAt
}
