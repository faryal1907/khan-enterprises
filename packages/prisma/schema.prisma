// ============================================================================
// KHAN DEALERSHIP PLATFORM
// Production-Grade Prisma Schema
// Stack: PostgreSQL + Prisma + NestJS
// ============================================================================

generator client {
  provider     = "prisma-client"
  output       = "./generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  ADMIN
  MANAGER
  SALES_STAFF
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum BikeStatus {
  AVAILABLE
  RESERVED
  SOLD
  IN_DELIVERY
}

enum OfferStatus {
  PENDING
  COUNTERED
  ACCEPTED
  REJECTED
  EXPIRED
  PAID
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  CONFIRMED
  READY_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum DeliveryStatus {
  REQUESTED
  UNDER_REVIEW
  APPROVED
  IN_TRANSIT
  DELIVERED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  SAFEPAY      // Phase 1 — Visa/Mastercard debit & credit cards
  JAZZCASH     // Phase 1 — Mobile wallet payments
  RAAST        // Phase 2 — Instant bank transfer via PayFast, zero MDR
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  PAYMENT
  REFUND
}

enum InventoryMovementType {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
  TRANSFER
  RESERVED
  RELEASED
}

enum FileType {
  SUPPLIER_INVOICE
  WARRANTY_DOCUMENT
  REGISTRATION_DOCUMENT
  SALES_INVOICE
  PAYMENT_RECEIPT
  SALE_AGREEMENT
}

// ============================================================================
// AUTH & USERS
// ============================================================================

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  fullName     String
  phoneNumber  String?
  role         UserRole
  status       UserStatus @default(ACTIVE)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  vendorId String?
  vendor   Vendor? @relation(fields: [vendorId], references: [id])

  refreshTokens RefreshToken[]

  auditLogs AuditLog[]

  createdOffers   Offer[] @relation("OfferCreatedBy")
  processedOrders Order[] @relation("OrderProcessedBy")

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  managedBranches Branch[]        @relation("BranchManager")
  stockMovements  StockMovement[]
  documents       Document[]

  @@index([email])
  @@index([role])
  @@index([branchId])
  @@index([vendorId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  expiresAt DateTime

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
}

// ============================================================================
// BRANCHES & VENDORS
// ============================================================================

model Branch {
  id          String  @id @default(uuid())
  name        String
  city        String
  address     String
  phoneNumber String?

  managerId String?
  manager   User?   @relation("BranchManager", fields: [managerId], references: [id])

  users User[]

  bikeInventory BikeUnit[]
  partInventory PartInventory[]

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, city])
}

model Vendor {
  id            String  @id @default(uuid())
  name          String
  contactPerson String?
  phoneNumber   String?
  email         String?
  address       String?

  suppliedBikes BikeUnit[]
  staff         User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// BIKE CATALOG
// ============================================================================

model BikeModel {
  id String @id @default(uuid())

  brand          String
  modelName      String
  year           Int
  engineCapacity String?
  color          String?

  description String?
  basePrice   Decimal @db.Decimal(12, 2)

  bikes BikeUnit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brand])
  @@index([modelName])
}

model BikeUnit {
  id String @id @default(uuid())

  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id])

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  modelId String
  model   BikeModel @relation(fields: [modelId], references: [id])

  chassisNumber String  @unique
  engineNumber  String  @unique
  serialNumber  String?

  status BikeStatus @default(AVAILABLE)

  negotiatedPrice Decimal? @db.Decimal(12, 2)

  reservedUntil DateTime?
  soldAt        DateTime?

  documents Document[]

  offers Offer[]
  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([branchId])
  @@index([modelId])
  @@index([vendorId])
  @@index([reservedUntil])
}

// ============================================================================
// PARTS & ACCESSORIES
// ============================================================================

model Part {
  id String @id @default(uuid())

  name     String
  sku      String @unique
  category String

  description  String?
  sellingPrice Decimal @db.Decimal(12, 2)

  inventories PartInventory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model PartInventory {
  id String @id @default(uuid())

  partId String
  part   Part   @relation(fields: [partId], references: [id])

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  quantity         Int @default(0)
  reservedQuantity Int @default(0)
  reorderLevel     Int @default(5)

  stockMovements StockMovement[]

  updatedAt DateTime @updatedAt

  @@unique([partId, branchId])
  @@index([branchId])
}

model StockMovement {
  id String @id @default(uuid())

  inventoryId String
  inventory   PartInventory @relation(fields: [inventoryId], references: [id])

  movementType InventoryMovementType

  quantity Int
  reason   String?

  performedById String?
  performedBy   User?   @relation(fields: [performedById], references: [id])

  createdAt DateTime @default(now())

  @@index([inventoryId])
}

// ============================================================================
// NEGOTIATION SYSTEM
// ============================================================================

model Offer {
  id String @id @default(uuid())

  bikeId String
  bike   BikeUnit @relation(fields: [bikeId], references: [id])

  customerName    String
  customerPhone   String
  customerEmail   String?
  customerCNIC    String?
  customerAddress String?

  offerAmount Decimal @db.Decimal(12, 2)

  counterAmount Decimal? @db.Decimal(12, 2)

  message       String?
  adminResponse String?

  status OfferStatus @default(PENDING)

  expiresAt DateTime?

  createdById String?
  createdBy   User?   @relation("OfferCreatedBy", fields: [createdById], references: [id])

  order Order?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bikeId])
  @@index([status])
  @@index([createdAt])
}

// ============================================================================
// ORDERS
// ============================================================================

model Order {
  id String @id @default(uuid())

  orderNumber String @unique

  bikeId String
  bike   BikeUnit @relation(fields: [bikeId], references: [id])

  offerId String? @unique
  offer   Offer?  @relation(fields: [offerId], references: [id])

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  customerName    String
  customerPhone   String
  customerCNIC    String
  customerAddress String

  negotiatedAmount Decimal @db.Decimal(12, 2)

  paymentMethod PaymentMethod

  status OrderStatus @default(PENDING_PAYMENT)

  processedById String?
  processedBy   User?   @relation("OrderProcessedBy", fields: [processedById], references: [id])

  transactions PaymentTransaction[]

  delivery DeliveryRequest?

  documents Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([branchId])
  @@index([createdAt])
}

// ============================================================================
// PAYMENTS
// ============================================================================

model PaymentTransaction {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  gatewayReference String? @unique
  idempotencyKey   String? @unique

  amount Decimal @db.Decimal(12, 2)

  method PaymentMethod

  status PaymentStatus @default(PENDING)

  gatewayResponse Json?

  failureReason String?

  webhookReceivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([gatewayReference])
}

// ============================================================================
// DELIVERY
// ============================================================================

model DeliveryRequest {
  id String @id @default(uuid())

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id])

  deliveryAddress     String
  preferredTimeWindow String?
  contactNumber       String

  status DeliveryStatus @default(REQUESTED)

  approvedAt  DateTime?
  deliveredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// ============================================================================
// DOCUMENT MANAGEMENT
// ============================================================================

model Document {
  id String @id @default(uuid())

  fileName String
  fileUrl  String

  mimeType String
  fileSize Int

  fileType FileType

  bikeId String?
  bike   BikeUnit? @relation(fields: [bikeId], references: [id])

  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id])

  uploadedById String?
  uploadedBy   User?   @relation(fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())

  @@index([fileType])
}

// ============================================================================
// AUDIT LOGS
// ============================================================================

model AuditLog {
  id String @id @default(uuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  userRole UserRole?

  action AuditAction

  entityType String
  entityId   String

  oldValue Json?
  newValue Json?

  ipAddress String?

  createdAt DateTime @default(now())

  @@index([entityType])
  @@index([entityId])
  @@index([action])
  @@index([createdAt])
}
